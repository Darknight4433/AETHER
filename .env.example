# ─── AETHER CONFIG ──────────────────────────────────────────────────────────
# Copy this to .env and fill in your values

# ElevenLabs TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # "Rachel" - change to your preferred voice

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3                          # or mistral, phi3, gemma2, etc.

# Whisper STT
WHISPER_MODEL=base                           # tiny | base | small | medium | large
WHISPER_LANGUAGE=en                          # Language hint (optional)

# Audio
AUDIO_INPUT_DEVICE=0                         # Sound device index (run audio_check.py to list)
SILENCE_THRESHOLD=500                        # RMS threshold for silence detection
SILENCE_DURATION=1.5                         # Seconds of silence before processing

# Screen Vision
SCREEN_CAPTURE_INTERVAL=0.5                  # Seconds between screen captures
CALL_DETECT_CONFIDENCE=0.75                  # Template match threshold (0-1)

# Aether Persona
AETHER_NAME=Aether
AETHER_SYSTEM_PROMPT=You are Aether, a calm and helpful AI assistant on a WhatsApp voice call. Keep your responses concise (2-3 sentences max). Be natural and conversational. Never mention that you are an AI unless directly asked.
